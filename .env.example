APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8084
APP_VERSION=1.0.0

# Database. Connection + credentials (the creds are also consumed by the db service).
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root_secret

# Initial admin user, created on first seed (InitialUserSeeder). The deployment's admin login.
INITIAL_USER_NAME="Admin"
INITIAL_USER_EMAIL=admin@omnigeek.test
INITIAL_USER_PASSWORD=password

QUEUE_CONNECTION=database

# Mail.
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@omnigeek.net"
MAIL_FROM_NAME=OmniGeek
