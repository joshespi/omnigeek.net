# Loaded automatically during tests, overriding OS env injected by docker-compose.
# Needed because root .env sets APP_ENV=local as a container OS var, which otherwise
# shadows phpunit's testing value and breaks Livewire's test-macro registration.
APP_ENV=testing
APP_KEY=base64:+5MPkA+aNfY+THzTX0w6p0w9azjWnSsPV43qMaz3TYU=
APP_DEBUG=true

DB_CONNECTION=sqlite
DB_DATABASE=:memory:

BCRYPT_ROUNDS=4
CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array
