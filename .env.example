# Deployment-specific config. Injected into the app container via docker-compose env_file,
# overriding the app defaults in src/.env. This file is the source of truth per deployment.

APP_ENV=local
# Generate with: docker compose run --rm app php artisan key:generate --show
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8084

# Database credentials (also consumed by the db service).
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root_secret

# First user / demo seeder (DemoPostsSeeder). Source of truth for the seeded admin account.
DEMO_USER_NAME="Demo Geek"
DEMO_USER_EMAIL=demo@omnigeek.test
DEMO_USER_PASSWORD=password
